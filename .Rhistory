DATA_DIR      <- "data"
args       <- commandArgs(trailingOnly = TRUE)
START_DATE <- if (length(args) >= 1) as.Date(args[1]) else today() - days(0)
END_DATE   <- if (length(args) >= 2) as.Date(args[2]) else today() - days(0)
dir.create(DATA_DIR, showWarnings = FALSE)
c_to_f <- function(c) round(as.numeric(c) * 9/5 + 32, 1)
# ── IEM ASOS: historical + recent data ────────────────────────────────────────
# Returns all METAR obs (routine + specials) with temp, dewpoint, wind, precip
# Same data source as weather.gov/wrh/timeseries
fetch_iem <- function(station_id, start_date, end_date, tz) {
url <- paste0(
"https://mesonet.agron.iastate.edu/cgi-bin/request/asos.py",
"?station=", station_id,
"&data=tmpf&data=dwpf&data=relh&data=sknt&data=drct&data=p01i&data=feel",
"&year1=",  year(start_date),  "&month1=", month(start_date), "&day1=", day(start_date),
"&year2=",  year(end_date),    "&month2=", month(end_date),   "&day2=", day(end_date),
"&tz=",     URLencode(tz, reserved = TRUE),
"&format=onlycomma",
"&latlon=no",
"&missing=M",
"&trace=T",
"&direct=no",
"&report_type=3&report_type=1"  # routine hourly + specials
)
tmp <- tempfile(fileext = ".csv")
on.exit(unlink(tmp), add = TRUE)
result <- tryCatch(
suppressWarnings(download.file(url, destfile = tmp, quiet = TRUE, method = "libcurl")),
error = function(e) { message("  IEM download error: ", e$message); -1 }
)
if (result != 0 || !file.exists(tmp) || file.size(tmp) < 50) return(NULL)
raw <- readLines(tmp, warn = FALSE)
data_lines <- raw[!grepl("^#", raw)]
if (length(data_lines) <= 1) return(NULL)
df <- read_csv(paste(data_lines, collapse = "\n"),
show_col_types = FALSE,
col_types = cols(.default = "c"))
df %>%
filter(!is.na(valid), tmpf != "M", tmpf != "") %>%
mutate(
obs_local  = ymd_hm(valid, tz = tz, quiet = TRUE),
obs_utc    = with_tz(obs_local, "UTC"),
date_local = as_date(obs_local),
hour_local = hour(obs_local),
temp_f     = round(as.numeric(tmpf), 1),
temp_c     = round((temp_f - 32) * 5/9, 1),
dewpoint_f = suppressWarnings(as.numeric(dwpf)),
rh_pct     = suppressWarnings(as.numeric(relh)),
wind_kts   = suppressWarnings(as.numeric(sknt)),
wind_dir   = suppressWarnings(as.numeric(drct)),
precip_in  = suppressWarnings(as.numeric(p01i)),
feels_like_f = suppressWarnings(as.numeric(feel)),
source     = "IEM_ASOS"
) %>%
filter(!is.na(obs_local), !is.na(temp_f)) %>%
arrange(obs_utc)
}
# ── NWS API: live observations for today ──────────────────────────────────────
fetch_nws_live <- function(station_id, tz) {
url  <- sprintf("https://api.weather.gov/stations/%s/observations?limit=200", station_id)
resp <- GET(url,
add_headers("User-Agent" = "KalshiWeatherTracker/1.0"),
timeout(20))
if (status_code(resp) != 200) return(NULL)
parsed   <- fromJSON(rawToChar(content(resp, as = "raw")), flatten = TRUE)
features <- parsed$features
if (is.null(features) || nrow(features) == 0) return(NULL)
features %>%
transmute(
obs_utc      = ymd_hms(properties.timestamp, tz = "UTC"),
obs_local    = with_tz(obs_utc, tz),
date_local   = as_date(obs_local),
hour_local   = hour(obs_local),
temp_c       = round(as.numeric(properties.temperature.value), 1),
temp_f       = c_to_f(temp_c),
dewpoint_f   = c_to_f(as.numeric(properties.dewpoint.value)),
rh_pct       = round(as.numeric(properties.relativeHumidity.value), 1),
wind_kts     = round(as.numeric(properties.windSpeed.value) * 0.539957, 1), # m/s to kts
wind_dir     = as.numeric(properties.windDirection.value),
precip_in    = NA_real_,
feels_like_f = NA_real_,
source       = "NWS_API"
) %>%
filter(!is.na(temp_c)) %>%
arrange(obs_utc)
}
# ── Main ──────────────────────────────────────────────────────────────────────
stations <- read_csv(STATIONS_FILE, show_col_types = FALSE)
today_date <- today()
message(sprintf("Pulling timeseries for %d stations: %s to %s",
nrow(stations), START_DATE, END_DATE))
for (i in seq_len(nrow(stations))) {
st <- stations[i, ]
message(sprintf("\n--- %s (%s) ---", st$name, st$station_id))
outfile <- file.path(DATA_DIR, sprintf("timeseries_%s.csv", st$station_id))
# Split date range: historical (IEM) vs today (NWS live)
hist_end   <- min(END_DATE, today_date - days(1))
fetch_live <- END_DATE >= today_date
all_obs <- list()
# Historical via IEM
if (START_DATE <= hist_end) {
message(sprintf("  IEM: %s to %s", START_DATE, hist_end))
iem_data <- tryCatch(
fetch_iem(st$station_id, START_DATE, hist_end, st$timezone),
error = function(e) { message("  IEM error: ", e$message); NULL }
)
if (!is.null(iem_data) && nrow(iem_data) > 0) {
message(sprintf("  IEM: %d observations", nrow(iem_data)))
all_obs[[length(all_obs) + 1]] <- iem_data
}
}
# Live/today via NWS API
if (fetch_live) {
message("  NWS API: live observations for today")
nws_data <- tryCatch(
fetch_nws_live(st$station_id, st$timezone),
error = function(e) { message("  NWS error: ", e$message); NULL }
)
if (!is.null(nws_data) && nrow(nws_data) > 0) {
today_obs <- nws_data %>% filter(date_local == today_date)
message(sprintf("  NWS API: %d observations today", nrow(today_obs)))
all_obs[[length(all_obs) + 1]] <- today_obs
}
}
if (length(all_obs) == 0) {
message("  No data retrieved.")
next
}
new_data <- bind_rows(all_obs) %>%
mutate(station_id = st$station_id, station_name = st$name) %>%
select(station_id, station_name, obs_utc, obs_local, date_local,
hour_local, temp_f, temp_c, dewpoint_f, rh_pct,
wind_kts, wind_dir, precip_in, feels_like_f, source)
# Merge with existing, deduplicate on obs_utc
if (file.exists(outfile)) {
existing <- read_csv(outfile, col_types = cols(.default = "c"),
show_col_types = FALSE)
combined <- bind_rows(
existing,
new_data %>% mutate(across(everything(), as.character))
) %>%
distinct(station_id, obs_utc, .keep_all = TRUE) %>%
arrange(obs_utc)
} else {
combined <- new_data %>%
mutate(across(everything(), as.character)) %>%
arrange(obs_utc)
}
write_csv(combined, outfile)
message(sprintf("  Saved %d total rows to %s", nrow(combined), outfile))
}
all_obs
suppressPackageStartupMessages({
library(dplyr)
library(lubridate)
library(readr)
library(tidyr)
})
# ── Config ────────────────────────────────────────────────────────────────────
VC_API_KEY    <- Sys.getenv("VC_API_KEY", unset = "V4SNW3AZUFCLP544CBFMHJSRZ")
STATIONS_FILE <- "stations.csv"
DATA_DIR      <- "data"
args       <- commandArgs(trailingOnly = TRUE)
START_DATE <- if (length(args) >= 1) as.Date(args[1]) else today() - days(0)
END_DATE   <- if (length(args) >= 2) as.Date(args[2]) else today() - days(0)
dir.create(DATA_DIR, showWarnings = FALSE)
if (VC_API_KEY == "YOUR_VC_API_KEY_HERE") {
stop(paste0(
"Visual Crossing API key not set.\n",
"Add this line to your .Renviron file (~/.Renviron):\n",
"  VC_API_KEY=your_key_here\n",
"Then restart R. Sign up free: https://www.visualcrossing.com"
))
}
c_to_f <- function(c) round(as.numeric(c) * 9/5 + 32, 1)
# ── Source 1: IEM ASOS ────────────────────────────────────────────────────────
fetch_iem <- function(station_id, start_date, end_date, tz) {
url <- paste0(
"https://mesonet.agron.iastate.edu/cgi-bin/request/asos.py",
"?station=", station_id,
"&data=tmpf&data=dwpf&data=relh&data=sknt&data=drct&data=p01i&data=feel",
"&year1=",  year(start_date),  "&month1=", month(start_date), "&day1=", day(start_date),
"&year2=",  year(end_date),    "&month2=", month(end_date),   "&day2=", day(end_date),
"&tz=",     URLencode(tz, reserved = TRUE),
"&format=onlycomma&latlon=no&missing=M&trace=T&direct=no",
"&report_type=3&report_type=1"  # routine hourly + specials
)
tmp <- tempfile(fileext = ".csv")
on.exit(unlink(tmp), add = TRUE)
result <- tryCatch(
suppressWarnings(download.file(url, destfile = tmp, quiet = TRUE, method = "libcurl")),
error = function(e) { message("    IEM error: ", e$message); -1 }
)
if (result != 0 || !file.exists(tmp) || file.size(tmp) < 50) return(NULL)
raw <- readLines(tmp, warn = FALSE)
data_lines <- raw[!grepl("^#", raw)]
if (length(data_lines) <= 1) return(NULL)
df <- read_csv(paste(data_lines, collapse = "\n"),
show_col_types = FALSE, col_types = cols(.default = "c"))
df %>%
filter(!is.na(valid), tmpf != "M", tmpf != "") %>%
mutate(
obs_local  = ymd_hm(valid, tz = tz, quiet = TRUE),
obs_utc    = with_tz(obs_local, "UTC"),
date_local = as_date(obs_local),
hour_local = hour(obs_local),
temp_f     = round(as.numeric(tmpf), 1),
dewpoint_f = suppressWarnings(as.numeric(dwpf)),
rh_pct     = suppressWarnings(as.numeric(relh)),
wind_kts   = suppressWarnings(as.numeric(sknt)),
wind_dir   = suppressWarnings(as.numeric(drct)),
precip_in  = suppressWarnings(as.numeric(p01i)),
feels_like_f = suppressWarnings(as.numeric(feel))
) %>%
filter(!is.na(obs_local), !is.na(temp_f)) %>%
arrange(obs_utc)
}
# Aggregate IEM sub-hourly obs to one row per hour
# Use the obs closest to the top of the hour, fall back to max temp
agg_iem_hourly <- function(df) {
df %>%
mutate(mins_past_hour = minute(obs_local)) %>%
group_by(date_local, hour_local) %>%
arrange(abs(mins_past_hour - 53)) %>%   # METAR is typically at :53
summarise(
iem_obs_time    = first(format(obs_local, "%H:%M")),
iem_temp_f      = first(temp_f),
iem_temp_f_max  = max(temp_f, na.rm = TRUE),
iem_dewpoint_f  = first(dewpoint_f),
iem_rh_pct      = first(rh_pct),
iem_wind_kts    = first(wind_kts),
iem_wind_dir    = first(wind_dir),
iem_precip_in   = suppressWarnings(sum(precip_in, na.rm = TRUE)),
iem_n_obs       = n(),
.groups = "drop"
) %>%
mutate(hour_local = as.integer(hour_local))
}
# ── Source 2: Visual Crossing ─────────────────────────────────────────────────
fetch_vc <- function(lat, lon, start_date, end_date, api_key) {
# Request specific elements — exclude 'pressure' to avoid tidyselect conflict
elements <- paste0(
"datetime,temp,feelslike,dew,humidity,precip,",
"windspeed,winddir,conditions,source"
)
url <- sprintf(
paste0(
"https://weather.visualcrossing.com/VisualCrossingWebServices/rest/services/timeline/",
"%.4f%%2C%.4f/%s/%s",
"?unitGroup=us&include=hours&contentType=csv",
"&elements=%s&key=%s"
),
lat, lon,
format(start_date, "%Y-%m-%d"),
format(end_date,   "%Y-%m-%d"),
URLencode(elements, reserved = TRUE),
api_key
)
tmp <- tempfile(fileext = ".csv")
on.exit(unlink(tmp), add = TRUE)
result <- tryCatch(
suppressWarnings(download.file(url, destfile = tmp, quiet = TRUE, method = "libcurl")),
error = function(e) { message("    VC download error: ", e$message); -1 }
)
if (result != 0 || !file.exists(tmp) || file.size(tmp) < 100) {
if (file.exists(tmp)) {
msg <- tryCatch(readLines(tmp, n = 2, warn = FALSE), error = function(e) "")
if (length(msg) > 0) message("    VC response: ", msg[1])
}
return(NULL)
}
# Read raw and inspect columns before renaming
df_raw <- tryCatch(
read_csv(tmp, show_col_types = FALSE, col_types = cols(.default = "c")),
error = function(e) { message("    VC CSV read error: ", e$message); NULL }
)
if (is.null(df_raw)) return(NULL)
# VC CSV: first col is 'name' (location), second is 'datetime'
# Filter to hourly rows only (datetime contains "T")
df_raw <- df_raw %>% filter(grepl("T", datetime, fixed = TRUE))
if (nrow(df_raw) == 0) {
message("    VC: no hourly rows found in response")
return(NULL)
}
# Rename safely — only rename columns that exist
rename_map <- c(
temp        = "vc_temp_f",
feelslike   = "vc_feels_like_f",
dew         = "vc_dewpoint_f",
humidity    = "vc_rh_pct",
precip      = "vc_precip_in",
windspeed   = "vc_wind_mph",
winddir     = "vc_wind_dir",
conditions  = "vc_conditions",
source      = "vc_source"
)
# Only rename cols present in the data
rename_map <- rename_map[names(rename_map) %in% names(df_raw)]
df_raw %>%
rename(!!!setNames(names(rename_map), unname(rename_map))) %>%
mutate(
vc_temp_f      = as.numeric(vc_temp_f),
vc_dewpoint_f  = as.numeric(vc_dewpoint_f),
vc_rh_pct      = as.numeric(vc_rh_pct),
vc_wind_mph    = as.numeric(vc_wind_mph),
vc_wind_dir    = as.numeric(vc_wind_dir),
vc_precip_in   = as.numeric(vc_precip_in)
)
}
parse_vc_times <- function(df, tz) {
if (is.null(df) || nrow(df) == 0) return(NULL)
df %>%
mutate(
obs_local  = ymd_hms(datetime, tz = tz, quiet = TRUE),
obs_utc    = with_tz(obs_local, "UTC"),
date_local = as_date(obs_local),
hour_local = as.integer(hour(obs_local))
) %>%
filter(!is.na(obs_local), !is.na(vc_temp_f))
}
# ── NWS live obs for today ────────────────────────────────────────────────────
fetch_nws_today <- function(station_id, tz) {
url  <- sprintf("https://api.weather.gov/stations/%s/observations?limit=50", station_id)
resp <- tryCatch(
{
con <- url(url, headers = list("User-Agent" = "KalshiWeatherTracker/1.0"))
on.exit(close(con))
jsonlite::fromJSON(readLines(con, warn = FALSE), flatten = TRUE)
},
error = function(e) NULL
)
if (is.null(resp) || is.null(resp$features) || nrow(resp$features) == 0) return(NULL)
resp$features %>%
transmute(
obs_utc    = lubridate::ymd_hms(properties.timestamp, tz = "UTC", quiet = TRUE),
obs_local  = with_tz(obs_utc, tz),
date_local = as_date(obs_local),
hour_local = hour(obs_local),
temp_f     = c_to_f(as.numeric(properties.temperature.value)),
dewpoint_f = c_to_f(as.numeric(properties.dewpoint.value)),
rh_pct     = round(as.numeric(properties.relativeHumidity.value), 1),
wind_kts   = round(as.numeric(properties.windSpeed.value) * 0.539957, 1),
wind_dir   = as.numeric(properties.windDirection.value),
precip_in  = NA_real_,
feels_like_f = NA_real_
) %>%
filter(!is.na(temp_f), date_local == today(tzone = tz))
}
# ── Main ──────────────────────────────────────────────────────────────────────
stations   <- read_csv(STATIONS_FILE, show_col_types = FALSE)
today_date <- today()
dates_n    <- as.integer(END_DATE - START_DATE) + 1
est_records <- dates_n * 24 * nrow(stations)
message(sprintf("Pulling observations for %d stations: %s to %s",
nrow(stations), START_DATE, END_DATE))
message(sprintf("Estimated VC API records: %d (free limit: 1,000/day)", est_records))
all_combined <- list()
for (i in seq_len(nrow(stations))) {
st <- stations[i, ]
message(sprintf("\n--- %s (%s) ---", st$name, st$station_id))
# ── IEM (historical) + NWS (today if needed) ──────────────────────────────
hist_end   <- min(END_DATE, today_date - days(1))
iem_hourly <- NULL
if (START_DATE <= hist_end) {
message(sprintf("  IEM: fetching %s to %s...", START_DATE, hist_end))
raw_iem <- tryCatch(
fetch_iem(st$station_id, START_DATE, hist_end, st$timezone),
error = function(e) { message("  IEM failed: ", e$message); NULL }
)
if (!is.null(raw_iem) && nrow(raw_iem) > 0) {
iem_hourly <- agg_iem_hourly(raw_iem)
message(sprintf("  IEM: %d station-hours retrieved", nrow(iem_hourly)))
}
}
if (END_DATE >= today_date) {
message("  NWS API: fetching live obs for today...")
nws_today <- tryCatch(
fetch_nws_today(st$station_id, st$timezone),
error = function(e) { message("  NWS failed: ", e$message); NULL }
)
if (!is.null(nws_today) && nrow(nws_today) > 0) {
nws_agg <- agg_iem_hourly(nws_today %>%
rename(tmpf = temp_f, dwpf = dewpoint_f, relh = rh_pct,
sknt = wind_kts, drct = wind_dir,
p01i = precip_in, feel = feels_like_f) %>%
mutate(across(everything(), as.character)) %>%
mutate(
tmpf = as.numeric(tmpf),
dwpf = as.numeric(dwpf),
relh = as.numeric(relh),
sknt = as.numeric(sknt),
drct = as.numeric(drct),
p01i = as.numeric(p01i),
feel = as.numeric(feel)
) %>%
# re-run the fetch properly
{ fetch_nws_today(st$station_id, st$timezone) }
)
# simpler approach: just use NWS as-is
nws_agg <- nws_today %>%
mutate(mins_past_hour = minute(obs_local)) %>%
group_by(date_local, hour_local) %>%
arrange(abs(mins_past_hour - 53)) %>%
summarise(
iem_obs_time   = first(format(obs_local, "%H:%M")),
iem_temp_f     = first(temp_f),
iem_temp_f_max = max(temp_f, na.rm = TRUE),
iem_dewpoint_f = first(dewpoint_f),
iem_rh_pct     = first(rh_pct),
iem_wind_kts   = first(wind_kts),
iem_wind_dir   = first(wind_dir),
iem_precip_in  = NA_real_,
iem_n_obs      = n(),
.groups        = "drop"
)
message(sprintf("  NWS: %d hours today", nrow(nws_agg)))
iem_hourly <- bind_rows(iem_hourly, nws_agg)
}
}
# ── Visual Crossing ────────────────────────────────────────────────────────
message(sprintf("  VC: fetching %s to %s...", START_DATE, END_DATE))
raw_vc <- tryCatch(
fetch_vc(st$lat, st$lon, START_DATE, END_DATE, VC_API_KEY),
error = function(e) { message("  VC failed: ", e$message); NULL }
)
vc_hourly <- NULL
if (!is.null(raw_vc) && nrow(raw_vc) > 0) {
vc_hourly <- parse_vc_times(raw_vc, st$timezone) %>%
select(date_local, hour_local,
vc_temp_f, vc_dewpoint_f, vc_rh_pct, vc_wind_mph,
vc_wind_dir, vc_precip_in, vc_conditions, vc_source)
message(sprintf("  VC:  %d hours | Temp range: %.1f–%.1f°F",
nrow(vc_hourly),
min(vc_hourly$vc_temp_f, na.rm = TRUE),
max(vc_hourly$vc_temp_f, na.rm = TRUE)))
}
# ── Join ───────────────────────────────────────────────────────────────────
# Build a complete hour spine for the date range
all_hours <- expand.grid(
date_local = seq(START_DATE, END_DATE, by = "day"),
hour_local = 0L:23L
) %>% as_tibble()
combined <- all_hours %>%
left_join(if (!is.null(iem_hourly)) iem_hourly else tibble(),
by = c("date_local", "hour_local")) %>%
left_join(if (!is.null(vc_hourly)) vc_hourly else tibble(),
by = c("date_local", "hour_local")) %>%
mutate(
station_id   = st$station_id,
station_name = st$name,
# Difference metrics
temp_diff_f  = round(vc_temp_f - iem_temp_f, 1),
abs_diff_f   = abs(temp_diff_f),
flag         = case_when(
is.na(iem_temp_f) | is.na(vc_temp_f) ~ "missing",
abs_diff_f >= 5  ~ "LARGE_DIFF",
abs_diff_f >= 3  ~ "moderate_diff",
TRUE             ~ "ok"
)
) %>%
select(
station_id, station_name, date_local, hour_local,
# IEM/NWS columns
iem_obs_time, iem_temp_f, iem_temp_f_max, iem_dewpoint_f,
iem_rh_pct, iem_wind_kts, iem_wind_dir, iem_precip_in, iem_n_obs,
# Visual Crossing columns
vc_temp_f, vc_dewpoint_f, vc_rh_pct, vc_wind_mph,
vc_wind_dir, vc_precip_in, vc_conditions, vc_source,
# Comparison
temp_diff_f, abs_diff_f, flag
) %>%
arrange(date_local, hour_local)
# Print discrepancy summary
flagged <- combined %>% filter(flag %in% c("LARGE_DIFF", "moderate_diff"))
if (nrow(flagged) > 0) {
message(sprintf("  ⚠ %d hours flagged (≥3°F diff):", nrow(flagged)))
flagged %>%
select(date_local, hour_local, iem_temp_f, vc_temp_f, temp_diff_f, vc_source, flag) %>%
print(n = 20)
} else if (!is.null(iem_hourly) && !is.null(vc_hourly)) {
mae <- mean(combined$abs_diff_f, na.rm = TRUE)
message(sprintf("  ✓ No large discrepancies (MAE: %.2f°F)", mae))
}
# Save per-station file
outfile <- file.path(DATA_DIR, sprintf("observations_%s.csv", st$station_id))
if (file.exists(outfile)) {
existing <- read_csv(outfile, col_types = cols(.default = "c"), show_col_types = FALSE)
combined_out <- bind_rows(
existing,
combined %>% mutate(across(everything(), as.character))
) %>%
distinct(station_id, date_local, hour_local, .keep_all = TRUE) %>%
arrange(date_local, hour_local)
} else {
combined_out <- combined %>% mutate(across(everything(), as.character))
}
write_csv(combined_out, outfile)
all_combined[[i]] <- combined
Sys.sleep(0.3)
}
all_combined[[2]]
all_combined[[3]]
all_combined[[4]]
all_combined[[5]]
all_combined[[5]] %>%
select(hour_local, vc_temp_f, iem_temp_f)
all_combined[[5]] %>%
select(hour_local, vc_temp_f, iem_temp_f) %>%
print(n = 10)
all_combined[[5]] %>%
select(hour_local, vc_temp_f, iem_temp_f) %>%
print(n = 100)
